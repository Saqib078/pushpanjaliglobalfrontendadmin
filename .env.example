# Admin API base URL (no trailing slash). Must match where the Admin backend is reachable
# in the browser. Vite proxies /uploads → this host so uploaded images load on the admin UI.
# On LAN, use your machine IP, e.g. http://192.168.1.10:8081
# Production example: https://admin.yoursite.com
VITE_ADMIN_API_URL=http://localhost:8081

# Web storefront dev URL (no trailing slash). Vite proxies /images → here so legacy paths
# like /images/amla_candy.jpg match the shop (FeaturedPickles fallbacks).
# Production: your live shop origin (must also be listed in Web API WEB_CORS_ORIGINS)
VITE_WEB_PORTAL_ORIGIN=http://localhost:5173

# vite build --mode production: add .env.production with the same keys pointing at live URLs.
